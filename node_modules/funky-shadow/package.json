{
  "name": "funky-shadow",
  "version": "0.1.0",
  "description": "Dithered gradient shadows for any element. Canvas-rendered with Bayer matrix thresholding and Oklab color interpolation.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "license": "MIT",
  "author": "iamnoman",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamnoman/funky-shadow"
  },
  "keywords": [
    "shadow",
    "dithered",
    "gradient",
    "pixel",
    "bayer",
    "react",
    "css",
    "canvas"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/react": "^18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  }
}
